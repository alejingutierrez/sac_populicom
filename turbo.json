{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "cdk.out/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    },
    "test": {
      "outputs": [
        "coverage/**"
      ]
    },
    "test:integration": {
      "outputs": []
    },
    "test:e2e": {
      "dependsOn": [
        "build"
      ],
      "outputs": [
        "playwright-report/**",
        "test-results/**"
      ]
    }
  }
}
