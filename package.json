{
  "name": "sac-populicom",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "bins:link": "node ./scripts/link-local-bins.mjs",
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:integration": "turbo test:integration",
    "test:e2e": "turbo test:e2e --filter=@sac/web",
    "test:perf": "node ./scripts/perf-web.mjs",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "prepare": "husky",
    "db:generate": "pnpm --filter @sac/db db:generate",
    "db:migrate": "pnpm --filter @sac/db db:migrate",
    "amplify:status": "tsx ./scripts/amplify-status.ts",
    "amplify:start-job": "tsx ./scripts/amplify-start-job.ts",
    "brandwatch:profile": "tsx ./scripts/profile-brandwatch-export.ts",
    "brandwatch:import": "tsx ./scripts/import-brandwatch-export.ts",
    "brandwatch:invoke-import": "tsx ./scripts/invoke-brandwatch-import.ts",
    "stack:invoke-lambda": "tsx ./scripts/invoke-stack-lambda.ts"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,md,yml,yaml,css}": "prettier --write"
  },
  "devDependencies": {
    "@aws-sdk/client-amplify": "^3.925.0",
    "@aws-sdk/client-cloudformation": "^3.925.0",
    "@aws-sdk/client-lambda": "^3.925.0",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.39.1",
    "@next/eslint-plugin-next": "^15.5.6",
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.10.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.4",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^3.2.4"
  }
}
